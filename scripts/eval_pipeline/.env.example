# Codeforces API Credentials
# Required for fetching problems and submitting code
COOKIES="your_codeforces_login_cookies_here"
KEY="your_api_key_here"
SECRET="your_api_secret_here"
TURNSTILE_TOKEN="optional_cloudflare_turnstile_token_here"

# LLM Provider API Keys
# You only need the keys for the models you plan to run

# OpenAI (used for gpt-5.4, o3)
OPENAI_API_KEY="sk-..."

# Anthropic (used for claude-opus-4-5)
ANTHROPIC_API_KEY="sk-ant-..."

# Mistral (used for mistral-large-latest)
MISTRAL_API_KEY="..."

# Moxonshot/Kimi (used for kimi-k2.5)
MOONSHOT_API_KEY="sk-..."

# Google Gemini (comma-separated list for rate-limit rotation)
GEMINI_API_KEYS="AIzaSy...,AIzaSy...,AIzaSy..."
